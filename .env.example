# --- Core ---
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json
FRONTEND_URL=https://localhost
ADMIN_URL=https://localhost:4001
PATIENT_URL=https://localhost:4002

# --- Postgres ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=hs
POSTGRES_PASSWORD=change_me_dev_only
POSTGRES_DB=hipaa_scheduler
DATABASE_URL=postgresql+asyncpg://hs:change_me_dev_only@postgres:5432/hipaa_scheduler

# --- Auth ---
JWT_SECRET=change_me_dev_only_min_32_chars_long_xxxxx
JWT_ISSUER=hipaa-scheduler
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7
SESSION_IDLE_MIN=15
MFA_REQUIRED_DEFAULT=true

# --- Admin bootstrap ---
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change_me_dev_only
SUPER_ADMIN_EMAILS=admin@example.com

# --- Rate limiting ---
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_PUBLIC_BOOKING=30/minute

# --- HIPAA ---
PHI_AUDIT_ENABLED=true
RETENTION_YEARS=6

# --- Notifications ---
SENDGRID_API_KEY=
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=Practice Scheduler
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# --- Object storage (documents/consents) ---
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=

# --- Calendar OAuth ---
GOOGLE_OAUTH_ID=
GOOGLE_OAUTH_SECRET=
MS_OAUTH_ID=
MS_OAUTH_SECRET=

# --- Webhooks ---
WEBHOOK_HMAC_ALG=sha256
WEBHOOK_TIMEOUT_SEC=5
WEBHOOK_MAX_ATTEMPTS=6

# --- Observability ---
SENTRY_DSN=

# --- Outer nginx (host ports) ---
HTTP_PORT=80
HTTPS_PORT=443

# --- Backup (backup.sh) ---
# Encrypted nightly pg_dump uploaded to object storage.
# BACKUP_ENCRYPTION_RECIPIENT is an age public key (age1...)
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=hipaa-scheduler/postgres
BACKUP_ENCRYPTION_RECIPIENT=
